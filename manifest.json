{
	"manifest_version": 3,
	"name": "stock helper",
	"version": "1.0",
	"description": "a simple info of stock",
	"action": {
		"default_icon": {
			"16": "images/icon16.png",
			"48": "images/icon48.png",
			"128": "images/icon128.png"
		},
		"default_title": "stock helper",
		"default_popup": "popup.html"
	},
	"icons": {
		"16": "images/icon16.png",
		"48": "images/icon48.png",
		"128": "images/icon128.png"
	},
	"permissions": [],
	"host_permissions": [
		"http://qt.gtimg.cn/*"
	],
	"background": {
		"service_worker": "background.js"
	}
}